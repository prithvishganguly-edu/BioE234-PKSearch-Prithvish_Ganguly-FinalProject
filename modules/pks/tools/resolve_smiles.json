{
  "id": "org.bioe234.function.pks.resolve_smiles.v1",
  "name": "Resolve Chemical Name to SMILES",
  "description": "Resolve a chemical name (common, trade, or IUPAC) to a canonical SMILES string via PubChem. If the input is already valid SMILES, returns it immediately without a network call.",
  "type": "function",
  "keywords": [
    "SMILES",
    "chemical name",
    "PubChem",
    "name resolution",
    "molecule lookup",
    "IUPAC",
    "canonical SMILES"
  ],
  "date_created": null,
  "date_last_modified": null,

  "inputs": [
    {
      "name": "query",
      "type": "string",
      "description": "Chemical name (e.g. \"erythromycin\", \"butyric acid\") or SMILES string to resolve."
    }
  ],

  "outputs": [
    {
      "type": "object",
      "description": "Object with keys: smiles (string), molecular_formula (string), iupac_name (string), source (\"rdkit\" or \"pubchem\"), cid (integer or null)."
    }
  ],

  "examples": [
    {
      "input": { "query": "erythromycin" },
      "output": {
        "result": {
          "smiles": "CC[C@@H]1[C@@]([C@@H]([C@H](C(=O)...",
          "molecular_formula": "C37H67NO13",
          "iupac_name": "(3R,4S,5S,6R,...)-...",
          "source": "pubchem",
          "cid": 12560
        }
      },
      "notes": "Common antibiotic name resolved via PubChem."
    },
    {
      "input": { "query": "CCCC(=O)O" },
      "output": {
        "result": {
          "smiles": "CCCC(=O)O",
          "molecular_formula": "",
          "iupac_name": "",
          "source": "rdkit",
          "cid": null
        }
      },
      "notes": "Already-valid SMILES; returns immediately without network call."
    }
  ],

  "execution_details": {
    "language": "Python",
    "source": "modules/pks/tools/resolve_smiles.py",
    "initialization": "initiate",
    "execution": "run",
    "disposal": null,

    "mcp_name": "resolve_smiles",
    "seq_params": []
  },

  "trigger_phrases": [
    "resolve chemical name",
    "look up SMILES for",
    "what is the SMILES of",
    "convert name to SMILES",
    "find SMILES for"
  ],

  "dependencies": {
    "pip": ["requests", "rdkit"]
  }
}
